rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // TODO: Tighten these rules before going to production.
    // Currently open read/write because auth is handled client-side via PIN.
    // Future improvement: issue short-lived tokens on PIN success and validate here.

    match /{document=**} {
      allow read, write: if true;
    }
  }
}
